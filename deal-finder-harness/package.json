{
  "name": "deal-finder-harness",
  "version": "1.0.0",
  "description": "Scenario harness for Deal Finder MCP-native validation",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx src/tests/**/*.test.ts",
    "start": "node dist/index.js",
    "auth:mcp": "tsx src/auth/mcpAuthBootstrap.ts"
  },
  "keywords": [
    "xyn",
    "harness",
    "mcp"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.4.2",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
