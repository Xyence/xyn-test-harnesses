NODE_ENV=development
LOG_LEVEL=info
XYN_UI_BASE_URL=http://localhost:3000
MCP_SERVER_ID=deal-finder-mcp
MCP_BASE_URL=https://mcp.example.com
MCP_AUTH_TOKEN_FILE=./.auth/mcp-token.json
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
XYN_OIDC_CLIENT_ID=
MCP_ENDPOINT_SUBMIT_REQUEST=/mcp/development/requests
# TODO: fill these only when confirmed.
# MCP_ENDPOINT_ARTIFACT_SELECTION=
# MCP_ENDPOINT_PLANNER_OUTPUT=
# MCP_ENDPOINT_SIBLING_INFO=
# MCP_ENDPOINT_SIBLING_URL=
# MCP_ENDPOINT_BRANCH_INFO=
ARTIFACTS_DIR=./artifacts
PLAYWRIGHT_STORAGE_STATE=./artifacts/playwright/storage-state.json
PLAYWRIGHT_HEADLESS=true
# Set to a specific scenario id or "all" to run every scenario file.
HARNESS_SCENARIO_ID=phase1_minimal_command_palette_change

# auth:mcp bootstrap settings
MCP_AUTH_TOKEN_MODE=access_token
MCP_ID_TOKEN_AUDIENCE=
MCP_AUTH_PROBE_PATH=/
MCP_AUTH_CALLBACK_HOST=127.0.0.1
MCP_AUTH_CALLBACK_PORT=8787
MCP_AUTH_TIMEOUT_MS=180000
GOOGLE_OAUTH_SCOPES=openid email profile

# Required selectors for real Playwright command palette verifier.
# Leave blank only if you intentionally want fail-closed behavior.
XYN_SELECTOR_APP_SHELL_ROOT=
XYN_SELECTOR_AUTH_LOGGED_IN_MARKER=
XYN_SELECTOR_COMMAND_PALETTE_TRIGGER=
XYN_SELECTOR_COMMAND_PALETTE_INPUT=
XYN_SELECTOR_COMMAND_PALETTE_RESULTS=

# Optional datasource selectors.
XYN_SELECTOR_DATASOURCE_LIST=
XYN_SELECTOR_DATASOURCE_ROW=
XYN_SELECTOR_DATASOURCE_TOAST=
